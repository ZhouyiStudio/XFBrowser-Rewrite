+    case ContentSettingsType::ADS:
+    case ContentSettingsType::TRACKING_PROTECTION:
+    case ContentSettingsType::COOKIES:
+      return true;  // XFBrowser: block tracking by default
+    default:
+      return false;
+  }
 }
 
 void ContentSettingsPref::SetBlockAllThirdPartyCookies(bool block) {
-  // XFBrowser: Always block third-party cookies
