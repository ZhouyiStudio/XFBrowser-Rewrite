+// XFBrowser: Fluent UI v2 Tab Strip
+#include "chrome/browser/ui/views/tabs/tab_strip.h"
 
 TabStrip::TabStrip(std::unique_ptr<TabStripController> controller)
     : controller_(std::move(controller)) {
-  // XFBrowser: Use Fluent rounded tab shapes
-  SetBackground(nullptr);
-  SetPaintToLayer(ui::LAYER_TEXTURED);
-  layer()->SetFillsBoundsOpaquely(false);
-  layer()->SetRoundedCornerRadius(gfx::RoundedCornersF(8));
-  layer()->SetIsFastRoundedCorner(true);
+  ConfigureFluentTabStyle();
 }
 
+void TabStrip::ConfigureFluentTabStyle() {
+  SetBackground(nullptr);
+  SetPaintToLayer(ui::LAYER_TEXTURED);
+  layer()->SetFillsBoundsOpaquely(false);
+  layer()->SetRoundedCornerRadius(gfx::RoundedCornersF(8));
+  layer()->SetIsFastRoundedCorner(true);
+}
+
 void TabStrip::PaintChildren(const views::PaintInfo& paint_info) {
-  // XFBrowser: Fluent soft shadows
-  cc::PaintFlags flags;
-  flags.setAntiAlias(true);
-  flags.setStyle(cc::PaintFlags::kFill_Style);
-  flags.setColor(SK_ColorTRANSPARENT);
-  // Fluent shadow effect applied via DrawShadow
+  // Fluent shadow rendering
+  PaintFluentTabShadow(paint_info);
   views::View::PaintChildren(paint_info);
 }
 
+void TabStrip::PaintFluentTabShadow(const views::PaintInfo& paint_info) {
+  auto* canvas = paint_info.context();
+  if (!canvas) return;
+  
+  cc::PaintFlags flags;
+  flags.setAntiAlias(true);
+  flags.setStyle(cc::PaintFlags::kFill_Style);
+  
+  // Soft Fluent shadow beneath tabs
+  for (size_t i = 0; i < tab_count(); ++i) {
+    auto* tab = tab_at(i);
+    if (!tab || !tab->GetVisible()) continue;
+    
+    gfx::Rect shadow_bounds = tab->bounds();
+    // Fluent shadow offset
+    shadow_bounds.Offset(0, 2);
+    flags.setColor(SkColorSetA(SK_ColorBLACK, 8));
+    canvas->DrawRoundRect(shadow_bounds, 8, flags);
+  }
+}

