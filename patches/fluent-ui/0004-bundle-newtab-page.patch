From: XFBrowser <dev@xfbrowser.org>
Date: Sun, 21 Jun 2026 12:00:00 +0800
Subject: Register XFBrowser new tab page as a built-in extension

Register xfbrowser-newtab in browser/extensions/moz.build so that
Firefox bundles the custom new tab page as a system addon.

diff --git a/browser/extensions/moz.build b/browser/extensions/moz.build
--- a/browser/extensions/moz.build
+++ b/browser/extensions/moz.build
@@ -5,6 +5,7 @@

 DIRS += [
     'report-site-issue',
     'screenshots',
     'webcompat',
+    'xfbrowser-newtab',
 ]
