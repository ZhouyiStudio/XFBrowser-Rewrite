From: XFBrowser <dev@xfbrowser.org>
Date: Sun, 21 Jun 2026 12:00:00 +0800
Subject: Bundle XFBrowser Fluent new tab extension as a system addon

Add the XFBrowser new tab page extension to Firefox's built-in system
addons. This automatically overrides about:newtab with the Fluent UI
new tab page.

diff --git a/browser/extensions/moz.build b/browser/extensions/moz.build
--- a/browser/extensions/moz.build
+++ b/browser/extensions/moz.build
@@ -5,6 +5,7 @@

 DIRS += [
     'report-site-issue',
     'screenshots',
     'webcompat',
+    'xfbrowser-newtab',
 ]

 with Files("**"):

diff --git a/browser/extensions/xfbrowser-newtab/manifest.json b/browser/extensions/xfbrowser-newtab/manifest.json
new file mode 100644
--- /dev/null
+++ b/browser/extensions/xfbrowser-newtab/manifest.json
@@ -0,0 +1,15 @@
+{
+  "manifest_version": 2,
+  "name": "XFBrowser 新标签页",
+  "version": "1.0.0",
+  "description": "XFBrowser Fluent UI 新标签页",
+  "chrome_url_overrides": {
+    "newtab": "newtab/index.html"
